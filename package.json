{
  "name": "gulag-api",
  "version": "1.0.1",
  "description": "",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "ssh://git@gitlab.urbica.co:2222/gulag/api.git"
  },
  "main": "index.js",
  "scripts": {
    "db:create": "pg-migrate -m ./src/db/migrations new",
    "db:migrate": "pg-migrate -m ./src/db/migrations migrate",
    "db:rollback": "pg-migrate -m ./src/db/migrations rollback",
    "db:reset": "pg-migrate -m ./src/db/migrations reset",
    "cz": "git-cz",
    "lint": "eslint src",
    "precommit": "lint-staged",
    "release": "standard-version",
    "start": "API_PORT=3001 nodemon index.js",
    "test": "jest"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js}": [
      "prettier-eslint --write",
      "yarn lint --fix",
      "git add"
    ]
  },
  "devDependencies": {
    "commitizen": "4.0.3",
    "cz-conventional-changelog": "3.0.2",
    "eslint": "4.19.1",
    "eslint-config-airbnb-base": "12.1.0",
    "eslint-config-prettier": "2.10.0",
    "eslint-plugin-import": "2.18.2",
    "eslint-plugin-jest": "21.27.2",
    "husky": "3.0.7",
    "jest": "22.4.4",
    "lint-staged": "7.3.0",
    "nodemon": "1.19.3",
    "prettier": "1.18.2",
    "prettier-eslint": "8.8.2",
    "prettier-eslint-cli": "4.7.1",
    "standard-version": "7.0.0",
    "supertest": "3.4.2"
  },
  "dependencies": {
    "@urbica/pg-migrate": "1.1.0",
    "bluebird": "3.5.5",
    "dotenv": "5.0.1",
    "jsonwebtoken": "8.5.1",
    "kcors": "2.2.2",
    "koa": "2.8.2",
    "koa-bodyparser": "4.2.1",
    "koa-jwt": "3.6.0",
    "koa-multer": "1.0.2",
    "koa-router": "7.4.0",
    "pg": "7.12.1"
  }
}
